# ─────────────────────────────────────────────────────────────────────────────
# Environment variables required for Vercel deployment
# Copy these into your Vercel project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (use Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret — generate a long random string (e.g. openssl rand -hex 64)
SESSION_SECRET=replace-with-a-long-random-secret

# Admin login credentials for the /admin panel
ADMIN_EMAIL=admin@clashlayoutshub.com
ADMIN_PASSWORD=replace-with-strong-password

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be: https://clashlayoutshub.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://clashlayoutshub.com/api/auth/google/callback

# ─── Password reset emails (optional — logs to console if not set) ───────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@clashlayoutshub.com
SMTP_PASS=your-smtp-password
SMTP_FROM="ClashLayoutsHub" <noreply@clashlayoutshub.com>
# Used in reset password emails — set to your Vercel domain or custom domain
RESET_BASE_URL=https://clashlayoutshub.com

# ─── Cloudflare Turnstile (optional CAPTCHA) ─────────────────────────────────
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ─── Google AdSense (optional) ───────────────────────────────────────────────
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
